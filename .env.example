# MamaCare Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# ─── Google Cloud Speech-to-Text ─────────────────────────────────────────────
# Required for voice symptom checker (BUG-003 fix)
# Create at: https://console.cloud.google.com/apis/credentials
# Enable: Cloud Speech-to-Text API
EXPO_PUBLIC_GOOGLE_STT_KEY=YOUR_GOOGLE_STT_API_KEY_HERE

# ─── MamaCare Backend API ─────────────────────────────────────────────────────
# Base URL for your Node.js / Express backend
# Used by: CHW dashboard, consent logging, CHW visit scheduling, deletion API
EXPO_PUBLIC_API_BASE_URL=https://api.mamacare.app

# ─── Africa's Talking (SMS / USSD) ───────────────────────────────────────────
# Used by backend sms-ussd-gateway.js
# Get keys at: https://africastalking.com
AFRICASTALKING_API_KEY=YOUR_AFRICASTALKING_API_KEY_HERE
AFRICASTALKING_USERNAME=mamacare

# ─── App Security ─────────────────────────────────────────────────────────────
# Session timeout in milliseconds (default 30 minutes)
# Change here; SessionManager reads this at startup
SESSION_TIMEOUT_MS=1800000

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Set to 'true' to enable, 'false' to disable
EXPO_PUBLIC_VOICE_ENABLED=true
EXPO_PUBLIC_USSD_ENABLED=true
EXPO_PUBLIC_CHW_DASHBOARD_ENABLED=true
