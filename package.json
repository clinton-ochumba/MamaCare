{
  "name": "mamacare",
  "version": "1.0.0",
  "private": true,
  "main": "App.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build": "expo export --platform web --output-dir web-build",
    "test": "jest --testEnvironment node --no-coverage",
    "test:coverage": "jest --testEnvironment node --coverage",
    "test:watch": "jest --testEnvironment node --watch",
    "test:safety": "jest --testEnvironment node --no-coverage --testPathPattern='riskAssessment|EmergencyAlertManager' --verbose",
    "test:security": "jest --testEnvironment node --no-coverage --testPathPattern='security/securityAudit' --verbose",
    "test:accessibility": "jest --testEnvironment node --no-coverage --testPathPattern='accessibility/accessibilityAudit' --verbose",
    "test:gates": "npm run test:safety && npm run test:security && npm run test:accessibility",
    "lint": "eslint src backend --ext .js,.jsx",
    "lint:fix": "eslint src backend --ext .js,.jsx --fix",
    "precommit": "npm run lint && npm run test:gates"
  },
  "dependencies": {
    "@expo/metro-runtime": "~3.2.3",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/stack": "^6.3.0",
    "expo": "~51.0.0",
    "expo-av": "~14.0.0",
    "expo-build-properties": "~0.12.5",
    "expo-file-system": "~17.0.0",
    "expo-secure-store": "~13.0.0",
    "expo-sms": "~12.0.0",
    "expo-speech": "~12.0.0",
    "expo-status-bar": "~1.12.0",
    "react": "18.2.0",
    "react-dom": "^18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.0",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-web": "^0.19.13",
    "react-native-webview": "13.8.6",
    "typescript": "~5.3.3"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/eslint-parser": "^7.24.0",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/preset-env": "^7.24.0",
    "@testing-library/react-native": "^12.4.0",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "~11.0.0",
    "body-parser": "^1.20.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-native": "^4.1.0",
    "expo-build-properties": "^0.8.0",
    "express": "^4.18.3",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-expo": "~51.0.0",
    "react-native-builder-bob": "^0.23.2",
    "supertest": "^6.3.4"
  },
  "expo": {
    "install": {
      "exclude": ["typescript"]
    }
  }
}
